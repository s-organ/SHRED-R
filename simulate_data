# Single common component correlation .... ####

p = 300
n = 1000
k = 100
rho = 0.5 

X <- genCorGen(n,p,params1 = c(rep(0,p)), params2 = c(rep(1,p)), rho = rho, dist = "normal", corstr = "cs")

X <- X %>% dplyr::select(id, X) %>% as.data.frame()
sim_data2 = data.frame(matrix(ncol = p, nrow = n))
ls <- list()
for(i in 1:n){
  ls[[i]] <- unlist(c(X[X$id == i,2]))
  names(ls[[i]]) = NULL
  sim_data2[i,] = ls[[i]]
}

X = sim_data2 %>% as.matrix()

nonzero = sample(p, k)
bs = rnorm(nonzero,0,1)
beta = rep(0,p)
beta[nonzero] = bs
y = X %*% beta + rnorm(n)

true = nonzero


