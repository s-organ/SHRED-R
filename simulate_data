# Clustered correlation .... ####


p <- 300
n <- 1000
k <- 100


base_sizes <- c(5, 10, 15)
sizes <- c()

while(sum(sizes) + min(base_sizes) <= p){
  sizes <- c(sizes, base_sizes)
}

if(sum(sizes) < p){
  sizes <- c(sizes, p - sum(sizes))
}

K <- length(sizes)

set.seed(1)
rho_k <- runif(K, min = 0.3, max = 0.6)

Sigma <- matrix(0, p, p)

start <- 1
for(j in 1:K){
  
  m <- sizes[j]
  end <- start + m - 1
  
  block <- matrix(rho_k[j], m, m)
  diag(block) <- 1
  
  Sigma[start:end, start:end] <- block
  start <- end + 1
}


X <- MASS::mvrnorm(n, mu = rep(0, p), Sigma = Sigma)

nonzero <- sample(p, k)
beta <- rep(0, p)
beta[nonzero] <- rnorm(k, 0, 1)

y <- X %*% beta + rnorm(n)

true = nonzero

